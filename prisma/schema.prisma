generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("DRIVER")
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managedVehicles Vehicle[]
  assignedTrips   Trip[]    @relation("DriverTrips")
  managedTrips    Trip[]    @relation("ManagerTrips")
}

model Vehicle {
  id            String   @id @default(cuid())
  vehicleNumber String   @unique
  driverName    String
  driverPhone   String
  permitId      String
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  managerId String
  manager   User   @relation(fields: [managerId], references: [id])

  trips     Trip[]
  alerts    Alert[]
  locations VehicleLocation[]
}

model Trip {
  id           String   @id @default(cuid())
  origin       String
  destination  String
  originLat    Float    @default(0)
  originLng    Float    @default(0)
  destLat      Float    @default(0)
  destLng      Float    @default(0)
  cargo        String
  permitId     String
  allowedTrips Int      @default(1)
  status       String   @default("PENDING")
  startTime    DateTime?
  endTime      DateTime?
  routeTaken   String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  driverId String
  driver   User   @relation("DriverTrips", fields: [driverId], references: [id])

  managerId String
  manager   User   @relation("ManagerTrips", fields: [managerId], references: [id])

  alerts Alert[]
}

model Alert {
  id        String   @id @default(cuid())
  type      String
  message   String
  severity  String   @default("WARNING")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
}

model VehicleLocation {
  id        String   @id @default(cuid())
  lat       Float
  lng       Float
  speed     Float    @default(0)
  heading   Float    @default(0)
  timestamp DateTime @default(now())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
}
